{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMultipleMajorReleases",
    "group:allNonMajor",
    "schedule:weekends"
  ],
  "timezone": "America/Chicago",
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"],
    "automerge": true
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "automerge": true,
    "schedule": ["at any time"],
    "minimumReleaseAge": "0 days"
  },
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "description": "Auto-merge dev dependency patch + minor",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Auto-merge runtime patch updates after 3-day bake",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group Next.js + React ecosystem",
      "matchPackageNames": [
        "next",
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom"
      ],
      "groupName": "next/react"
    },
    {
      "description": "Group Prisma",
      "matchPackageNames": ["prisma", "@prisma/**"],
      "groupName": "prisma"
    },
    {
      "description": "Group Radix UI",
      "matchPackageNames": ["@radix-ui/**"],
      "groupName": "radix-ui",
      "automerge": true
    },
    {
      "description": "Group Tailwind ecosystem",
      "matchPackageNames": ["tailwindcss", "@tailwindcss/**", "tailwind-merge", "tailwindcss-animate"],
      "groupName": "tailwind"
    },
    {
      "description": "Group Sentry",
      "matchPackageNames": ["@sentry/**"],
      "groupName": "sentry"
    },
    {
      "description": "Pin GitHub Actions to SHAs",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    },
    {
      "description": "Hold major framework/runtime upgrades for manual review",
      "matchPackageNames": ["next", "react", "react-dom", "prisma", "@prisma/**", "node"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major-upgrade"],
      "minimumReleaseAge": "7 days"
    }
  ],
  "postUpdateOptions": ["bunUpdate"]
}
