/build
/dist

# TypeScript — regenerated by `next dev` / `next build` / `next typegen`.
# Next.js 16's isolatedDevBuild (default-on) emits typegen to .next/dev for
# dev mode and .next for build, so this file's `import "./.next/.../types/
# routes.d.ts"` line legitimately differs between the two — tracking it
# causes ping-pong commits. Vercel guidance: ignore it, regen via
# `next typegen` in CI if a typecheck needs to run on a fresh checkout.
# Refs: nextjs.org/docs/app/api-reference/config/typescript ,
# github.com/vercel/next.js/issues/85738 ,
# github.com/vercel/next.js blob/canary/packages/create-next-app/templates
# /default-empty/ts/gitignore (line 41).
next-env.d.ts

