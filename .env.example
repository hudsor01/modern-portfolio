# ──────────────────────────────────────────────────────────────────────────────
# modern-portfolio — example environment file
# ──────────────────────────────────────────────────────────────────────────────
# Copy to `.env.local` (git-ignored) and fill in real values.
# Canonical schema & validation: src/lib/env-validation.ts (Zod, validated at
# startup). Anything declared here that is NOT in that file is read directly by
# application code (logger, Sentry, scripts, etc.) and documented below.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Runtime mode ─────────────────────────────────────────────────────────────
# development | production | test
NODE_ENV=development

# ─── Database (PostgreSQL via Neon or local Postgres) ─────────────────────────
# Must start with postgresql:// or postgres://
# Build-time is optional (see SKIP_DB_VALIDATION); required at runtime.
DATABASE_URL=postgresql://user:password@host:5432/modern_portfolio?sslmode=require

# Use the local pg adapter instead of @prisma/adapter-neon. Set to "true" when
# running a local Postgres in development.
USE_LOCAL_DB=false

# Skip the db.ts startup check — used by CI so the build doesn't require a live
# DB. Leave unset locally.
# SKIP_DB_VALIDATION=true

# ─── Site ─────────────────────────────────────────────────────────────────────
# Must be HTTPS in production. Drives CSP, canonical URLs, OG metadata,
# sitemap generation, and CORS.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated CORS allowlist (transformed to string[] at startup).
# Example: https://richardwhudsonjr.com,https://www.richardwhudsonjr.com
ALLOWED_ORIGINS=

# Used only by scripts/generate-sitemap.js if NEXT_PUBLIC_SITE_URL is unset.
# SITE_URL=https://richardwhudsonjr.com

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Required for the /contact form. Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Sender address (must be verified in your Resend domain).
FROM_EMAIL=contact@richardwhudsonjr.com

# Inbox address that receives contact-form submissions.
TO_EMAIL=hello@richardwhudsonjr.com

# Optional override for TO_EMAIL. When set, the server action in
# src/app/contact/actions.ts prefers CONTACT_EMAIL.
# CONTACT_EMAIL=hello@richardwhudsonjr.com

# ─── Observability (Sentry) ───────────────────────────────────────────────────
# DSN for the Sentry project that receives runtime errors. Present on client
# (NEXT_PUBLIC_*) AND server — pick either SENTRY_DSN or the public one; the
# server config falls back to the public DSN.
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=

# Environment label for Sentry (prod/preview/staging/etc.). Falls back to
# NODE_ENV if unset.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# SENTRY_ENVIRONMENT=

# Sampling rates (0.0 – 1.0). Defaults: 0.1 in production, 1.0 elsewhere.
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_PROFILES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# Send PII (IP, cookies) to Sentry — leave unset/false unless explicitly needed.
# SENTRY_SEND_DEFAULT_PII=false
# NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII=false

# Source-map upload credentials (used by @sentry/nextjs webpack plugin during
# `next build`). Typically only set in CI / Vercel.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
# SENTRY_URL=https://sentry.io

# ─── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error | fatal
# Defaults: info in production, debug elsewhere.
# LOG_LEVEL=info

# Opt-in file transport in production. Leave false unless you have a mounted
# writable path.
# ENABLE_FILE_LOGGING=false

# ─── SEO / Verification ───────────────────────────────────────────────────────
# Google Search Console HTML-meta verification token (rendered into
# <meta name="google-site-verification"> via shared-metadata).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# IndexNow key for /api/blog push notifications to Bing/Yandex.
# INDEXNOW_KEY=

# ─── Auth / tokens (schema-validated but currently optional) ──────────────────
# JWT signing key — min 32, max 512 chars. Not currently used by any route;
# reserved for future admin endpoints.
# JWT_SECRET=
# Format: 1h | 30m | 7d
# JWT_EXPIRES_IN=

# Bearer token required to hit admin endpoints (min 32 chars).
# ADMIN_API_TOKEN=

# Bearer token required to hit /api/metrics (min 32 chars).
# METRICS_API_TOKEN=

# ─── Vercel-injected (do NOT set manually) ────────────────────────────────────
# VERCEL_URL=
# NEXT_PUBLIC_VERCEL_URL=
# NEXT_PHASE=             # set to phase-production-build during next build
# NEXT_BUILD_ID=          # stable per deploy
# NEXT_RUNTIME=           # nodejs | edge
